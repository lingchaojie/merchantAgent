{
  "name": "merchant-agent-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "merchantAgent desktop shell (Electron + Vite + React + TS) — Electron UI + Go backend (agentd)",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "electron-vite build",
    "typecheck:node": "tsc -p tsconfig.node.json --noEmit",
    "typecheck:web": "tsc -p tsconfig.web.json --noEmit",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "vitest run",
    "capability:generate": "node scripts/generate-reference-capability.mjs",
    "rebuild:electron": "electron-rebuild -f -w better-sqlite3,keytar",
    "dist:dir": "electron-vite build && npm run rebuild:electron && electron-builder --dir",
    "dist:win": "electron-vite build && npm run rebuild:electron && electron-builder --win",
    "dist": "electron-vite build && npm run rebuild:electron && electron-builder"
  },
  "devDependencies": {
    "@electron/rebuild": "3.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/mssql": "12.3.0",
    "@types/node": "^22",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/react-test-renderer": "18.3.1",
    "@vitejs/plugin-react": "^4",
    "electron": "^33",
    "electron-builder": "^25",
    "electron-vite": "^2",
    "react-test-renderer": "18.3.1",
    "typescript": "^5",
    "vite": "^5",
    "vitest": "^2"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "keytar": "7.9.0",
    "mssql": "12.7.0",
    "node-sql-parser": "5.4.0",
    "react": "^18",
    "react-dom": "^18"
  },
  "build": {
    "appId": "com.merchantagent.desktop",
    "productName": "merchantAgent",
    "files": ["out/**"],
    "extraResources": [
      {
        "from": "resources/capabilities/reference-manufacturing.cap.json",
        "to": "capabilities/reference-manufacturing.cap.json"
      },
      {
        "from": "resources/capabilities/reference-public.pem",
        "to": "capabilities/reference-public.pem"
      },
      {
        "from": "resources/implementation/platform-public.pem",
        "to": "implementation/platform-public.pem"
      }
    ],
    "npmRebuild": false,
    "asarUnpack": ["node_modules/better-sqlite3/**/*", "node_modules/keytar/**/*"],
    "win": { "target": ["nsis"] },
    "mac": { "target": ["dmg"] },
    "linux": { "target": ["AppImage"] }
  }
}
